# --- MongoDB ---
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>/?retryWrites=true&w=majority
MONGODB_DB=cmg

# --- Admin auth ---
ADMIN_SESSION_SECRET=

# --- GA4 ---
GA4_PROPERTY_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=

# --- Google OAuth (Sheets) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# --- CEO Money (/dashboard/ceo/money) ---
# Spreadsheet holding the Invoices / Payments / Targets / Config tabs.
#   Targets: period_start (the Friday), cash_target, revenue_target — both in SGD.
# Reuses the Google OAuth credentials above — the account behind
# GOOGLE_OAUTH_REFRESH_TOKEN must be able to open this sheet.
# Leave BLANK to run the page on deterministic sample data (it says so in a banner).
CEO_MONEY_SHEET_ID=
#
#
# The invoice register, read as the accounts team actually keeps it. Four columns:
#   A issue date | G currency (USD/SGD) | K gross amount | L status
# Revenue = the SGD total of column K for invoices dated inside the Friday–Thursday
# week. CANCELLED and CREDIT NOTE rows are excluded; the footer says how many.
# Independent of CEO_MONEY_SHEET_ID above, so revenue can go live while cash and
# receivables are still being mapped.
# Leave BLANK to fall back to sample invoices instead (the banner says so).
CEO_INVOICE_REGISTER_SHEET_ID=
CEO_INVOICE_REGISTER_TAB=SG Accounts
# Budget rates: SGD per 1 unit, applied to column K. Set once, not spot, so a week
# moves when the business moves and not when the FX market does. Overrides the
# defaults (USD 1.35, AUD 0.88, GBP 1.71, EUR 1.46, HKD 0.17); SGD is always 1.
# A currency with no rate is counted as ZERO and warned about, never guessed.
CEO_INVOICE_RATES=USD=1.35,AUD=0.88,GBP=1.71,EUR=1.46
#
# TESTING ONLY. Freezes the dashboard on the Friday–Thursday week containing this
# date, instead of the current week. Accepts 2026-06-19 or 6/19/26. The page shows
# a "Pinned week" banner whenever it is set. LEAVE BLANK IN PRODUCTION — a
# wallboard must follow the clock. A `?asOf=` URL parameter overrides this.
CEO_MONEY_AS_OF=

# --- CEO Marketing (/dashboard/ceo/marketing) ---
# Leads and cost per lead from the "Campaigns Report + Analysis" workbook,
# "Weekly Overall Report" tab. Reads the weekly block matching the viewed week:
# leads = sum of the sections' "Weekly Total Leads"; CPL = average of the
# sections' "CPL". Reuses the Google OAuth credentials above.
# Leave BLANK to run the page on sample data.
CEO_MARKETING_SHEET_ID=
# TESTING ONLY. Freezes the marketing page on the week containing this date.
# LEAVE BLANK IN PRODUCTION. A `?asOf=` URL parameter overrides this.
CEO_MARKETING_AS_OF=

# --- Vimeo ---
VIMEO_ACCESS_TOKEN=

# --- Mailchimp (per-brand audiences) ---
# JSON object keyed by display title:
# {"Brand Name":{"apiKey":"<key>-usX","server":"usX","listId":"<id>"}, ...}
MAILCHIMP_ACCOUNTS_JSON=

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
